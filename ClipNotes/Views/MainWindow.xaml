<Window x:Class="ClipNotes.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ClipNotes.ViewModels"
        xmlns:models="clr-namespace:ClipNotes.Models"
        Title="ClipNotes" Height="780" Width="900"
        Icon="pack://application:,,,/Resources/icon.ico"
        MinHeight="600" MinWidth="750"
        Background="{DynamicResource BgBrush}"
        WindowStartupLocation="CenterScreen"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        RenderOptions.ClearTypeHint="Enabled"
        Loaded="Window_Loaded" Closing="Window_Closing"
        StateChanged="Window_StateChanged"
        PreviewMouseLeftButtonUp="Window_PreviewMouseLeftButtonUp">
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>
    <Grid>
        <TabControl SelectedIndex="{Binding CurrentTab}" Margin="0" BorderThickness="0" Background="Transparent">

            <!-- ==================== RECORDING TAB (0) ==================== -->
            <TabItem Header="{DynamicResource loc_TabRecording}">
                <Grid Margin="32,24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Style="{StaticResource Heading}" Text="{DynamicResource loc_HeadRecording}"/>

                    <Border Grid.Row="1" Style="{StaticResource Card}">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="{Binding RecordingStatus}" Style="{StaticResource BaseText}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center" Margin="0,8,0,4"/>
                            <TextBlock Text="{Binding RecordingTime}"
                                       FontSize="56" FontWeight="Light" FontFamily="Segoe UI"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       HorizontalAlignment="Center" Margin="0,0,0,16"/>
                            <TextBlock Style="{StaticResource Label}" Text="{DynamicResource loc_LabelSessionName}"
                                       HorizontalAlignment="Center" Margin="0,0,0,4"
                                       Visibility="{Binding IsRecording, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}"/>
                            <TextBox Text="{Binding SessionName, UpdateSourceTrigger=PropertyChanged}"
                                     Width="200" HorizontalAlignment="Center" Margin="0,0,0,12"
                                     Visibility="{Binding IsRecording, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}"/>
                            <Button Style="{StaticResource PrimaryButton}" Content="{DynamicResource loc_BtnStartRecording}"
                                    Command="{Binding StartRecordingCommand}"
                                    HorizontalAlignment="Center" Margin="0,0,0,8"
                                    Visibility="{Binding IsRecording, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}"/>
                            <Button Style="{StaticResource DangerButton}" Content="{DynamicResource loc_BtnStopRecording}"
                                    Command="{Binding StopRecordingCommand}"
                                    HorizontalAlignment="Center"
                                    Visibility="{Binding IsRecording, Converter={StaticResource BoolToVis}}"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="2" Style="{StaticResource Card}"
                            Visibility="{Binding IsRecording, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SubHeading}" Text="{DynamicResource loc_SubHeadAddMarker}"
                                       HorizontalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                        PreviewMouseLeftButtonDown="MarkerButtons_MouseDown">
                                <Button Style="{StaticResource MarkerButton}" Content="Bug"
                                        Tag="{x:Static models:MarkerType.Bug}"
                                        Background="{DynamicResource BugBrush}"
                                        Command="{Binding AddMarkerCommand}" CommandParameter="{x:Static models:MarkerType.Bug}"/>
                                <Button Style="{StaticResource MarkerButton}" Content="Task"
                                        Tag="{x:Static models:MarkerType.Task}"
                                        Background="{DynamicResource TaskBrush}"
                                        Command="{Binding AddMarkerCommand}" CommandParameter="{x:Static models:MarkerType.Task}"/>
                                <Button Style="{StaticResource MarkerButton}" Content="Note"
                                        Tag="{x:Static models:MarkerType.Note}"
                                        Background="{DynamicResource NoteBrush}"
                                        Command="{Binding AddMarkerCommand}" CommandParameter="{x:Static models:MarkerType.Note}"/>
                                <Button Style="{StaticResource MarkerButton}" Content="Summary"
                                        Tag="{x:Static models:MarkerType.Summary}"
                                        Background="{DynamicResource SummaryBrush}"
                                        Command="{Binding AddMarkerCommand}" CommandParameter="{x:Static models:MarkerType.Summary}"/>
                            </StackPanel>

                            <!-- Hold mode indicator -->
                            <Border x:Name="HoldIndicator" Margin="0,10,0,0"
                                    Background="{Binding HoldingType, Converter={StaticResource MarkerTypeToBrush}}"
                                    CornerRadius="20" Padding="14,7"
                                    HorizontalAlignment="Center"
                                    Visibility="{Binding IsHolding, Converter={StaticResource BoolToVis}}">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="7" Height="7" Fill="White"
                                             VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding HoldingType}" Foreground="White"
                                               FontSize="13" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBlock Text="{Binding HoldingTimerText}" Foreground="White"
                                               FontFamily="Consolas" FontSize="15"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="3" Style="{StaticResource Card}">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Style="{StaticResource SubHeading}"
                                       Text="{Binding MarkersCountLabel}"/>
                            <ListView ItemsSource="{Binding Markers}" BorderThickness="0" Background="Transparent"
                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="40"/>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Index}" Style="{StaticResource BaseText}"
                                                       Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="{Binding TimestampFormatted}" Style="{StaticResource BaseText}"
                                                       FontFamily="Consolas" VerticalAlignment="Center"/>
                                            <Border Grid.Column="2" CornerRadius="4" Padding="8,2"
                                                    Background="{Binding Type, Converter={StaticResource MarkerTypeToBrush}}"
                                                    HorizontalAlignment="Left" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Type}" Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                                            </Border>
                                            <TextBlock Grid.Column="3" Text="{Binding HoldDurationText}"
                                                       Style="{StaticResource BaseText}" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       FontFamily="Consolas" Margin="8,0,0,0"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </DockPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ==================== REVIEW/EXPORT TAB (1) ==================== -->
            <TabItem Header="{DynamicResource loc_TabExport}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="32,24" MaxWidth="820">

                        <TextBlock Style="{StaticResource Heading}" Text="{DynamicResource loc_HeadExport}"/>

                        <!-- Load existing video (without OBS) -->
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SubHeading}" Text="{DynamicResource loc_SubHeadLoadVideo}"/>
                                <DockPanel Margin="0,0,0,12">
                                    <Button DockPanel.Dock="Right" Style="{StaticResource SecondaryButton}"
                                            Content="{DynamicResource loc_BtnBrowse}"
                                            Command="{Binding LoadExistingVideoCommand}" Margin="8,0,0,0"/>
                                    <TextBox Text="{Binding LoadedVideoPath, Mode=OneWay, TargetNullValue='—'}"
                                             IsReadOnly="True"/>
                                </DockPanel>
                                <TextBlock Style="{StaticResource Label}" Text="{DynamicResource loc_LabelManualMarker}" Margin="0,0,0,4"/>
                                <StackPanel Orientation="Horizontal">
                                    <TextBox Text="{Binding ManualMarkerTimecode, UpdateSourceTrigger=PropertyChanged}"
                                             Width="110" Margin="0,0,8,0" FontFamily="Consolas"/>
                                    <ComboBox ItemsSource="{Binding MarkerTypeOptions}"
                                              SelectedItem="{Binding ManualMarkerType}"
                                              Width="100" Margin="0,0,8,0">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border Padding="4,2" CornerRadius="4"
                                                        Background="{Binding Converter={StaticResource MarkerTypeToBrush}}">
                                                    <TextBlock Text="{Binding}" Foreground="White" FontWeight="SemiBold" FontSize="12"/>
                                                </Border>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                    <Button Style="{StaticResource SecondaryButton}" Content="{DynamicResource loc_BtnAdd}"
                                            Command="{Binding AddManualMarkerCommand}" Margin="0,0,8,0"/>
                                    <Button Style="{StaticResource SecondaryButton}" Content="{DynamicResource loc_BtnImportMarkers}"
                                            Command="{Binding ImportMarkersCommand}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Markers list -->
                        <Border Style="{StaticResource Card}">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Top" Style="{StaticResource SubHeading}"
                                           Text="{Binding MarkersCountLabel}"/>
                                <ListView ItemsSource="{Binding Markers}" BorderThickness="0" Background="Transparent"
                                          MaxHeight="300" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="36"/>
                                                    <ColumnDefinition Width="100"/>
                                                    <ColumnDefinition Width="72"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding Index}" Style="{StaticResource BaseText}"
                                                           Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="1" Text="{Binding TimestampFormatted}" Style="{StaticResource BaseText}"
                                                           FontFamily="Consolas" VerticalAlignment="Center"/>
                                                <Border Grid.Column="2" CornerRadius="4" Padding="8,2"
                                                        Background="{Binding Type, Converter={StaticResource MarkerTypeToBrush}}"
                                                        HorizontalAlignment="Left" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Type}" Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                                                </Border>
                                                <CheckBox Grid.Column="3" IsChecked="{Binding GenerateAudio}"
                                                          Content="{DynamicResource loc_CheckAudio}"
                                                          VerticalAlignment="Center" Margin="12,0,8,0"/>
                                                <CheckBox Grid.Column="4" IsChecked="{Binding GenerateText}"
                                                          Content="{DynamicResource loc_CheckText}"
                                                          VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="5" Text="{Binding HoldDurationText}"
                                                           Style="{StaticResource BaseText}" VerticalAlignment="Center"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           FontFamily="Consolas" Margin="8,0,0,0"/>
                                                <Button Grid.Column="6" Style="{StaticResource DangerButton}" Content="✕"
                                                        Padding="8,4" FontSize="12"
                                                        Command="{Binding DataContext.RemoveMarkerCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </DockPanel>
                        </Border>

                        <!-- Generation controls -->
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <StackPanel Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVis}}" Margin="0,0,0,12">
                                    <TextBlock Text="{Binding ProcessingStatus}" Style="{StaticResource BaseText}" Margin="0,0,0,8"/>
                                    <ProgressBar Value="{Binding ProcessingProgress}" Maximum="{Binding ProcessingTotal}"
                                                 Height="6" Foreground="{DynamicResource AccentBrush}"/>
                                </StackPanel>
                                <TextBlock Text="{Binding ProcessingStatus}" Style="{StaticResource BaseText}"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8"
                                           Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}"
                                           TextWrapping="Wrap"/>
                                <StackPanel Orientation="Horizontal">
                                    <Button Style="{StaticResource PrimaryButton}" Content="{DynamicResource loc_BtnGenerate}"
                                            Command="{Binding GenerateCommand}"
                                            IsEnabled="{Binding IsProcessing, Converter={StaticResource InverseBool}}"/>
                                    <Button Style="{StaticResource DangerButton}" Content="{DynamicResource loc_BtnCancel}"
                                            Command="{Binding CancelGenerationCommand}"
                                            Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVis}}"
                                            Margin="8,0,0,0"/>
                                    <Button Style="{StaticResource SecondaryButton}" Content="{DynamicResource loc_BtnOpenFolder}"
                                            Command="{Binding OpenSessionFolderCommand}" Margin="8,0,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Log output -->
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <DockPanel Margin="0,0,0,8">
                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                        <Button Style="{StaticResource SecondaryButton}"
                                                Content="{DynamicResource loc_BtnCopyLogs}"
                                                Command="{Binding CopyLogsToClipboardCommand}"
                                                Margin="0,0,8,0"/>
                                        <Button Style="{StaticResource SecondaryButton}"
                                                Content="{DynamicResource loc_BtnOpenLogs}"
                                                Command="{Binding OpenLogsFolderCommand}"/>
                                    </StackPanel>
                                    <TextBlock Style="{StaticResource SubHeading}"
                                               Text="{DynamicResource loc_SubHeadLogs}"
                                               VerticalAlignment="Center" Margin="0"/>
                                </DockPanel>
                                <TextBox x:Name="LogTextBox"
                                         Text="{Binding LogText, Mode=OneWay}"
                                         IsReadOnly="True"
                                         MaxHeight="160"
                                         FontFamily="Consolas"
                                         FontSize="11"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         TextChanged="LogTextBox_TextChanged"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ==================== HISTORY TAB (2) ==================== -->
            <TabItem Header="{DynamicResource loc_TabHistory}">
                <Grid Margin="32,24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="0,0,0,16">
                        <Button DockPanel.Dock="Right" Style="{StaticResource DangerButton}"
                                Content="{DynamicResource loc_BtnClearHistory}" Height="34"
                                Command="{Binding ClearHistoryCommand}"
                                Padding="12,0" VerticalAlignment="Center"/>
                        <TextBlock Style="{StaticResource Heading}" Text="{DynamicResource loc_HeadHistory}"
                                   VerticalAlignment="Center" Margin="0"/>
                    </DockPanel>

                    <Border Grid.Row="1" Style="{StaticResource Card}">
                        <ListView ItemsSource="{Binding SessionHistory}" BorderThickness="0" Background="Transparent">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding SessionName}" Style="{StaticResource BaseText}" FontWeight="Medium"/>
                                            <TextBlock Text="{Binding CreatedAt, StringFormat='{}{0:dd.MM.yyyy HH:mm}'}"
                                                       Style="{StaticResource BaseText}"
                                                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" VerticalAlignment="Center" Style="{StaticResource BaseText}"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   Text="{Binding MarkerCount, StringFormat='{}{0} markers'}"/>
                                        <Button Grid.Column="2" Style="{StaticResource SecondaryButton}"
                                                Content="{DynamicResource loc_BtnOpen}"
                                                Command="{Binding DataContext.OpenHistoryFolderCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding FolderPath}" Padding="12,6"/>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ==================== SETUP TAB (3) ==================== -->
            <TabItem Header="{DynamicResource loc_TabSettings}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Settings left nav -->
                    <Border Grid.Column="0" Background="{DynamicResource CardBrush}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0"
                            Padding="8,24,8,20" Width="168">
                        <StackPanel>
                            <Button Style="{StaticResource SettingsNavItem}" Content="OBS WebSocket"                               Click="NavTo_Obs"/>
                            <Button Style="{StaticResource SettingsNavItem}" Content="{DynamicResource loc_SubHeadOutputDir}"   Click="NavTo_OutputDir"/>
                            <Button Style="{StaticResource SettingsNavItem}" Content="{DynamicResource loc_SubHeadHotkeys}"     Click="NavTo_Hotkeys"/>
                            <Button Style="{StaticResource SettingsNavItem}" Content="{DynamicResource loc_SubHeadNaming}"      Click="NavTo_Naming"/>
                            <Button Style="{StaticResource SettingsNavItem}" Content="{DynamicResource loc_SubHeadTimecodes}"   Click="NavTo_Timecodes"/>
                            <Button Style="{StaticResource SettingsNavItem}" Content="{DynamicResource loc_SubHeadAudio}"       Click="NavTo_Audio"/>
                            <Button Style="{StaticResource SettingsNavItem}" Content="{DynamicResource loc_SubHeadTranscription}" Click="NavTo_Transcription"/>
                            <Button Style="{StaticResource SettingsNavItem}" Content="{DynamicResource loc_SubHeadCustomPaths}" Click="NavTo_CustomPaths"/>
                            <Button Style="{StaticResource SettingsNavItem}" Content="{DynamicResource loc_SubHeadHistorySet}"  Click="NavTo_HistorySet"/>
                            <Button Style="{StaticResource SettingsNavItem}" Content="{DynamicResource loc_SubHeadTheme}"       Click="NavTo_Theme"/>
                        </StackPanel>
                    </Border>

                    <ScrollViewer x:Name="SettingsScroll" Grid.Column="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel MaxWidth="820" Margin="24,24">
                        <TextBlock Style="{StaticResource Heading}" Text="{DynamicResource loc_HeadSettings}"/>

                        <!-- Tool status banner -->
                        <Border Background="{DynamicResource InfoBannerBgBrush}"
                                BorderBrush="{DynamicResource InfoBannerBorderBrush}"
                                BorderThickness="1" CornerRadius="8"
                                Padding="12,8" Margin="0,0,0,12">
                            <TextBlock Text="{Binding ToolsStatus}" Style="{StaticResource BaseText}"
                                       Foreground="{DynamicResource InfoBannerFgBrush}"
                                       TextWrapping="Wrap" FontSize="13"/>
                        </Border>

                        <!-- OBS Connection -->
                        <Border x:Name="CardObs" Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SubHeading}" Text="OBS WebSocket"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="100"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition/>
                                        <RowDefinition Height="8"/>
                                        <RowDefinition/>
                                        <RowDefinition Height="8"/>
                                        <RowDefinition/>
                                    </Grid.RowDefinitions>

                                    <StackPanel Grid.Row="0" Grid.Column="0">
                                        <TextBlock Style="{StaticResource Label}" Text="{DynamicResource loc_LabelObsHost}"/>
                                        <TextBox Text="{Binding ObsHost, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="0" Grid.Column="2">
                                        <TextBlock Style="{StaticResource Label}" Text="{DynamicResource loc_LabelObsPort}"/>
                                        <TextBox Text="{Binding ObsPort, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="2" Grid.ColumnSpan="3">
                                        <TextBlock Style="{StaticResource Label}" Text="{DynamicResource loc_LabelObsPassword}"/>
                                        <TextBox Text="{Binding ObsPassword, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="4" Grid.ColumnSpan="3" Orientation="Horizontal">
                                        <Button Style="{StaticResource PrimaryButton}" Content="{DynamicResource loc_BtnTestObs}"
                                                Command="{Binding TestObsConnectionCommand}"/>
                                        <TextBlock VerticalAlignment="Center" Margin="16,0,0,0"
                                                   Text="{Binding ObsStatus}" Style="{StaticResource BaseText}"/>
                                    </StackPanel>
                                </Grid>
                                <TextBlock Style="{StaticResource Label}" Text="{DynamicResource loc_LabelObsExe}" Margin="0,12,0,4"/>
                                <DockPanel Margin="0,0,0,8">
                                    <Button DockPanel.Dock="Right" Style="{StaticResource SecondaryButton}"
                                            Content="{DynamicResource loc_BtnBrowse}" Margin="8,0,0,0"
                                            Command="{Binding BrowseObsExeCommand}"/>
                                    <TextBox Text="{Binding ObsExePath, UpdateSourceTrigger=PropertyChanged}"/>
                                </DockPanel>
                                <CheckBox Content="{DynamicResource loc_CheckAutoStartObs}"
                                          IsChecked="{Binding AutoStartObs}"/>
                            </StackPanel>
                        </Border>

                        <!-- Output Directory -->
                        <Border x:Name="CardOutputDir" Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SubHeading}" Text="{DynamicResource loc_SubHeadOutputDir}"/>
                                <DockPanel>
                                    <Button DockPanel.Dock="Right" Style="{StaticResource SecondaryButton}"
                                            Content="{DynamicResource loc_BtnBrowse}"
                                            Command="{Binding BrowseOutputDirectoryCommand}" Margin="8,0,0,0"/>
                                    <TextBox Text="{Binding OutputRootDirectory, UpdateSourceTrigger=PropertyChanged}"/>
                                </DockPanel>
                            </StackPanel>
                        </Border>

                        <!-- Hotkeys -->
                        <Border x:Name="CardHotkeys" Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SubHeading}" Text="{DynamicResource loc_SubHeadHotkeys}"/>
                                <TextBlock Style="{StaticResource Label}" Text="{DynamicResource loc_LabelHotkeyHint}" Margin="0,0,0,8"/>
                                <ItemsControl ItemsSource="{Binding HotkeyBindings}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,0,0,6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="180"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding DisplayName}"
                                                           Style="{StaticResource BaseText}" VerticalAlignment="Center"/>
                                                <TextBox Grid.Column="1" Text="{Binding HotkeyText, Mode=OneWay}"
                                                         IsReadOnly="True" PreviewKeyDown="HotkeyTextBox_PreviewKeyDown"
                                                         GotFocus="HotkeyTextBox_GotFocus"
                                                         LostFocus="HotkeyTextBox_LostFocus"
                                                         Tag="{Binding}" Cursor="Hand"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- Session naming -->
                        <Border x:Name="CardNaming" Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SubHeading}" Text="{DynamicResource loc_SubHeadNaming}"/>
                                <CheckBox Content="{DynamicResource loc_CheckAskName}"
                                          IsChecked="{Binding AskSessionName}" Margin="0,0,0,8"/>
                                <CheckBox Content="{DynamicResource loc_CheckAppendDate}"
                                          IsChecked="{Binding AppendDateSuffix}" Margin="0,0,0,8"/>
                                <StackPanel Visibility="{Binding AppendDateSuffix, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Style="{StaticResource Label}" Margin="0,0,0,4"
                                               Text="{DynamicResource loc_LabelDateFormat}"/>
                                    <StackPanel Orientation="Horizontal">
                                        <ComboBox x:Name="DatePresetCombo"
                                                  Width="180" Margin="0,0,8,0"
                                                  SelectedIndex="0"
                                                  SelectionChanged="DateSuffixPreset_SelectionChanged">
                                            <ComboBoxItem Content="{DynamicResource loc_DatePreset_DM}"  Tag="{}_{dd}.{mm}"/>
                                            <ComboBoxItem Content="{DynamicResource loc_DatePreset_MY}"  Tag="{}_{mm}.{yyyy}"/>
                                            <ComboBoxItem Content="{DynamicResource loc_DatePreset_DMY}" Tag="{}_{dd}.{mm}.{yyyy}"/>
                                            <ComboBoxItem Content="{DynamicResource loc_DateFormatCustom}" Tag="Custom"/>
                                        </ComboBox>
                                        <TextBox Text="{Binding DateSuffixFormat, UpdateSourceTrigger=PropertyChanged}"
                                                 Width="200" FontFamily="Consolas"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Timecodes -->
                        <Border x:Name="CardTimecodes" Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SubHeading}" Text="{DynamicResource loc_SubHeadTimecodes}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Style="{StaticResource Label}" Text="{DynamicResource loc_LabelPreSec}"/>
                                        <TextBox Text="{Binding PreSeconds, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Style="{StaticResource Label}" Text="{DynamicResource loc_LabelPostSec}"/>
                                        <TextBox Text="{Binding PostSeconds, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>
                                </Grid>

                                <!-- Hold mode subsection -->
                                <Border Height="1" Background="{DynamicResource SeparatorBrush}" Margin="0,16,0,12"/>
                                <CheckBox Content="{DynamicResource loc_CheckHoldMode}" FontWeight="SemiBold"
                                          IsChecked="{Binding HoldModeEnabled}" Margin="0,0,0,8"/>
                                <TextBlock Style="{StaticResource Label}" TextWrapping="Wrap" Margin="0,0,0,8"
                                           Text="{DynamicResource loc_LabelHoldHint}"
                                           Visibility="{Binding HoldModeEnabled, Converter={StaticResource BoolToVis}}"/>
                                <Grid Visibility="{Binding HoldModeEnabled, Converter={StaticResource BoolToVis}}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Style="{StaticResource Label}" Text="{DynamicResource loc_LabelHoldPre}"/>
                                        <TextBox Text="{Binding HoldPreSeconds, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Style="{StaticResource Label}" Text="{DynamicResource loc_LabelHoldPost}"/>
                                        <TextBox Text="{Binding HoldPostSeconds, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Audio -->
                        <Border x:Name="CardAudio" Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SubHeading}" Text="{DynamicResource loc_SubHeadAudio}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Style="{StaticResource Label}" Text="{DynamicResource loc_LabelFormat}"/>
                                        <ComboBox ItemsSource="{Binding AudioCodecOptions}" SelectedItem="{Binding AudioCodec}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Style="{StaticResource Label}" Text="{DynamicResource loc_LabelBitrate}"/>
                                        <TextBox Text="{Binding AudioBitrate, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Transcription -->
                        <Border x:Name="CardTranscription" Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SubHeading}" Text="{DynamicResource loc_SubHeadTranscription}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Style="{StaticResource Label}" Text="{DynamicResource loc_LabelModel}"/>
                                        <ComboBox ItemsSource="{Binding ModelOptions}"
                                                  SelectedValuePath="Value"
                                                  SelectedValue="{Binding WhisperModel}">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="130"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="{Binding ModelName}" FontWeight="Medium"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding VramHint}"
                                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                                   Margin="4,0,0,0"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Style="{StaticResource Label}" Text="{DynamicResource loc_LabelLanguage}"/>
                                        <ComboBox ItemsSource="{Binding LanguageOptions}" SelectedItem="{Binding TranscriptionLanguage}"/>
                                    </StackPanel>
                                </Grid>
                                <TextBlock Style="{StaticResource Label}" Text="{DynamicResource loc_LabelGlossary}" Margin="0,12,0,4"/>
                                <TextBox Text="{Binding Glossary, UpdateSourceTrigger=PropertyChanged}"
                                         AcceptsReturn="True" Height="60" TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"/>
                                <TextBlock Style="{StaticResource Label}" Text="{DynamicResource loc_LabelGlossaryFile}" Margin="0,8,0,4"/>
                                <DockPanel>
                                    <Button DockPanel.Dock="Right" Style="{StaticResource SecondaryButton}"
                                            Content="{DynamicResource loc_BtnBrowse}" Margin="8,0,0,0"
                                            Command="{Binding BrowseGlossaryFileCommand}"/>
                                    <TextBox Text="{Binding GlossaryFilePath, UpdateSourceTrigger=PropertyChanged}"/>
                                </DockPanel>
                            </StackPanel>
                        </Border>

                        <!-- Custom output paths -->
                        <Border x:Name="CardCustomPaths" Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SubHeading}" Text="{DynamicResource loc_SubHeadCustomPaths}"/>
                                <TextBlock Style="{StaticResource Label}" TextWrapping="Wrap" Margin="0,0,0,8"
                                           Text="{DynamicResource loc_LabelCustomPathHint}"/>
                                <!-- Video -->
                                <StackPanel Margin="0,0,0,6">
                                    <CheckBox Content="{DynamicResource loc_CheckCustomVideo}"
                                              IsChecked="{Binding UseCustomVideoPath}" Margin="0,0,0,4"/>
                                    <StackPanel Visibility="{Binding UseCustomVideoPath, Converter={StaticResource BoolToVis}}">
                                        <DockPanel Margin="0,0,0,6">
                                            <Button DockPanel.Dock="Right" Style="{StaticResource SecondaryButton}"
                                                    Content="{DynamicResource loc_BtnBrowse}" Margin="8,0,0,0"
                                                    Command="{Binding BrowseCustomPathCommand}" CommandParameter="video"/>
                                            <TextBox Text="{Binding CustomVideoPath, UpdateSourceTrigger=PropertyChanged}"/>
                                        </DockPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <RadioButton Style="{StaticResource ModeButton}" GroupName="VideoPathMode"
                                                         Content="{DynamicResource loc_BtnMove}" Margin="0,0,4,0"
                                                         IsChecked="{Binding VideoPathCopy, Converter={StaticResource InverseBool}}"/>
                                            <RadioButton Style="{StaticResource ModeButton}" GroupName="VideoPathMode"
                                                         Content="{DynamicResource loc_BtnCopy}"
                                                         IsChecked="{Binding VideoPathCopy}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                                <!-- Audio -->
                                <StackPanel Margin="0,0,0,6">
                                    <CheckBox Content="{DynamicResource loc_CheckCustomAudio}"
                                              IsChecked="{Binding UseCustomAudioPath}" Margin="0,0,0,4"/>
                                    <StackPanel Visibility="{Binding UseCustomAudioPath, Converter={StaticResource BoolToVis}}">
                                        <DockPanel Margin="0,0,0,6">
                                            <Button DockPanel.Dock="Right" Style="{StaticResource SecondaryButton}"
                                                    Content="{DynamicResource loc_BtnBrowse}" Margin="8,0,0,0"
                                                    Command="{Binding BrowseCustomPathCommand}" CommandParameter="audio"/>
                                            <TextBox Text="{Binding CustomAudioPath, UpdateSourceTrigger=PropertyChanged}"/>
                                        </DockPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <RadioButton Style="{StaticResource ModeButton}" GroupName="AudioPathMode"
                                                         Content="{DynamicResource loc_BtnMove}" Margin="0,0,4,0"
                                                         IsChecked="{Binding AudioPathCopy, Converter={StaticResource InverseBool}}"/>
                                            <RadioButton Style="{StaticResource ModeButton}" GroupName="AudioPathMode"
                                                         Content="{DynamicResource loc_BtnCopy}"
                                                         IsChecked="{Binding AudioPathCopy}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                                <!-- Txt -->
                                <StackPanel Margin="0,0,0,6">
                                    <CheckBox Content="{DynamicResource loc_CheckCustomTxt}"
                                              IsChecked="{Binding UseCustomTxtPath}" Margin="0,0,0,4"/>
                                    <StackPanel Visibility="{Binding UseCustomTxtPath, Converter={StaticResource BoolToVis}}">
                                        <DockPanel Margin="0,0,0,6">
                                            <Button DockPanel.Dock="Right" Style="{StaticResource SecondaryButton}"
                                                    Content="{DynamicResource loc_BtnBrowse}" Margin="8,0,0,0"
                                                    Command="{Binding BrowseCustomPathCommand}" CommandParameter="txt"/>
                                            <TextBox Text="{Binding CustomTxtPath, UpdateSourceTrigger=PropertyChanged}"/>
                                        </DockPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <RadioButton Style="{StaticResource ModeButton}" GroupName="TxtPathMode"
                                                         Content="{DynamicResource loc_BtnMove}" Margin="0,0,4,0"
                                                         IsChecked="{Binding TxtPathCopy, Converter={StaticResource InverseBool}}"/>
                                            <RadioButton Style="{StaticResource ModeButton}" GroupName="TxtPathMode"
                                                         Content="{DynamicResource loc_BtnCopy}"
                                                         IsChecked="{Binding TxtPathCopy}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                                <!-- Table -->
                                <StackPanel>
                                    <CheckBox Content="{DynamicResource loc_CheckCustomTable}"
                                              IsChecked="{Binding UseCustomTablePath}" Margin="0,0,0,4"/>
                                    <StackPanel Visibility="{Binding UseCustomTablePath, Converter={StaticResource BoolToVis}}">
                                        <DockPanel Margin="0,0,0,6">
                                            <Button DockPanel.Dock="Right" Style="{StaticResource SecondaryButton}"
                                                    Content="{DynamicResource loc_BtnBrowse}" Margin="8,0,0,0"
                                                    Command="{Binding BrowseCustomPathCommand}" CommandParameter="table"/>
                                            <TextBox Text="{Binding CustomTablePath, UpdateSourceTrigger=PropertyChanged}"/>
                                        </DockPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <RadioButton Style="{StaticResource ModeButton}" GroupName="TablePathMode"
                                                         Content="{DynamicResource loc_BtnMove}" Margin="0,0,4,0"
                                                         IsChecked="{Binding TablePathCopy, Converter={StaticResource InverseBool}}"/>
                                            <RadioButton Style="{StaticResource ModeButton}" GroupName="TablePathMode"
                                                         Content="{DynamicResource loc_BtnCopy}"
                                                         IsChecked="{Binding TablePathCopy}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- History settings -->
                        <Border x:Name="CardHistorySet" Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SubHeading}" Text="{DynamicResource loc_SubHeadHistorySet}"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Style="{StaticResource Label}" Text="{DynamicResource loc_LabelMaxHistory}"
                                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBox Text="{Binding MaxHistoryCount, UpdateSourceTrigger=PropertyChanged}"
                                             Width="60"/>
                                </StackPanel>
                                <CheckBox Content="{DynamicResource loc_CheckDeleteFiles}"
                                          IsChecked="{Binding DeleteFilesOnClear}"
                                          Margin="0,0,0,6"/>
                                <CheckBox Content="{DynamicResource loc_CheckClearMarkers}"
                                          IsChecked="{Binding ClearMarkersOnVideoLoad}"/>
                            </StackPanel>
                        </Border>

                        <!-- Theme -->
                        <Border x:Name="CardTheme" Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SubHeading}" Text="{DynamicResource loc_SubHeadTheme}"/>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,12">
                                    <TextBlock Style="{StaticResource Label}" Text="{DynamicResource loc_LabelTheme}"
                                               VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <ComboBox SelectedIndex="{Binding SelectedThemeIndex}" Width="130">
                                        <ComboBoxItem Content="{DynamicResource loc_ThemeLight}"/>
                                        <ComboBoxItem Content="{DynamicResource loc_ThemeDark}"/>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,12">
                                    <TextBlock Style="{StaticResource Label}" Text="{DynamicResource loc_LabelAppLanguage}"
                                               VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <ComboBox ItemsSource="{Binding AvailableLanguages}"
                                              SelectedItem="{Binding SelectedLanguage}"
                                              Width="100"/>
                                </StackPanel>
                                <CheckBox Content="{DynamicResource loc_CheckStartWithWindows}"
                                          IsChecked="{Binding StartWithWindows}"
                                          Margin="0,0,0,8"/>
                                <CheckBox Content="{DynamicResource loc_CheckMinimizeToTray}"
                                          IsChecked="{Binding MinimizeToTray}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                    </ScrollViewer>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</Window>
