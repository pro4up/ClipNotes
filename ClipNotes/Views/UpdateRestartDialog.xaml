<Window x:Class="ClipNotes.Views.UpdateRestartDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ClipNotes"
        Width="420" SizeToContent="Height"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BgBrush}"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        Loaded="Window_Loaded">

    <Border Style="{StaticResource Card}" Margin="12">
        <StackPanel>

            <!-- Icon + Title row -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <TextBlock Text="&#x2B06;" FontSize="22"
                           Foreground="{DynamicResource AccentBrush}"
                           VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock x:Name="TitleText"
                           FontFamily="Segoe UI" FontSize="17" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Message -->
            <TextBlock x:Name="MessageText"
                       Style="{StaticResource BaseText}"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       TextWrapping="Wrap"
                       LineHeight="20"
                       Margin="0,0,0,20"/>

            <!-- Buttons row -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="LaterBtn"
                        Content="{DynamicResource loc_BtnLater}"
                        Style="{StaticResource SecondaryButton}"
                        Padding="18,8" Margin="0,0,8,0"
                        Click="Later_Click"/>
                <Button x:Name="RestartBtn"
                        Content="{DynamicResource loc_BtnRestartNow}"
                        Style="{StaticResource PrimaryButton}"
                        Padding="18,8"
                        Click="RestartNow_Click"/>
            </StackPanel>

        </StackPanel>
    </Border>
</Window>
