<Window x:Class="ClipNotes.Uninstaller.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Name="RootWindow"
        Width="480" Height="300"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BgBrush}"
        Icon="pack://application:,,,/Resources/icon.ico">
    <Grid Margin="32,28,32,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Подтверждение -->
        <StackPanel x:Name="ConfirmPanel" Grid.Row="0" VerticalAlignment="Center">
            <TextBlock x:Name="ConfirmTitleText"
                       FontSize="20" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       Margin="0,0,0,10"/>
            <TextBlock x:Name="InfoText"
                       FontSize="12"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       TextWrapping="Wrap"
                       LineHeight="18"
                       Margin="0,0,0,12"/>
            <CheckBox x:Name="DeleteUserDataCheckBox"
                      FontSize="12"
                      Foreground="{DynamicResource TextSecondaryBrush}"
                      IsChecked="True"/>
        </StackPanel>

        <!-- Результат -->
        <StackPanel x:Name="ResultPanel" Grid.Row="0" VerticalAlignment="Center"
                    Visibility="Collapsed">
            <TextBlock x:Name="ResultText"
                       FontSize="20" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,8"/>
            <TextBlock x:Name="ResultDetails"
                       FontSize="12"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       HorizontalAlignment="Center"
                       TextWrapping="Wrap"
                       TextAlignment="Center"/>
        </StackPanel>

        <!-- Кнопки подтверждения -->
        <StackPanel x:Name="ConfirmButtons" Grid.Row="2"
                    Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="CancelButton"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Margin="0,0,10,0"
                    Click="Cancel_Click"/>
            <Button x:Name="UninstallButton"
                    Style="{StaticResource DangerButtonStyle}"
                    Click="Uninstall_Click"/>
        </StackPanel>

        <!-- Кнопка закрытия (после результата) -->
        <Button x:Name="CloseButton" Grid.Row="2"
                Style="{StaticResource AccentButtonStyle}"
                HorizontalAlignment="Right"
                Visibility="Collapsed"
                Click="Close_Click"/>
    </Grid>
</Window>
