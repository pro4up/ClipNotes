<Window x:Class="ClipNotes.Setup.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ClipNotes Setup"
        Width="560" Height="540"
        MinWidth="560" MinHeight="540"
        MaxWidth="560" MaxHeight="540"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Icon="pack://application:,,,/Resources/icon.ico"
        Background="{DynamicResource BgBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>   <!-- Контент страниц -->
            <RowDefinition Height="Auto"/> <!-- Индикатор шагов -->
            <RowDefinition Height="64"/>  <!-- Навигация -->
        </Grid.RowDefinitions>

        <!-- Контентная область -->
        <ContentControl x:Name="PageContent" Grid.Row="0"/>

        <!-- Индикатор шагов -->
        <StackPanel Grid.Row="1" x:Name="StepIndicator"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,6,0,8"/>

        <!-- Разделитель + Навигационные кнопки -->
        <Border Grid.Row="2"
                BorderBrush="{DynamicResource SeparatorBrush}"
                BorderThickness="0,0.5,0,0"
                Padding="24,0">
            <Grid VerticalAlignment="Center">
                <Button x:Name="BackButton"
                        Content="Назад"
                        Style="{StaticResource SecondaryButtonStyle}"
                        HorizontalAlignment="Left"
                        Click="BackButton_Click"/>
                <Button x:Name="NextButton"
                        Content="Далее"
                        Style="{StaticResource AccentButtonStyle}"
                        HorizontalAlignment="Right"
                        Click="NextButton_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>
