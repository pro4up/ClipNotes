<UserControl x:Class="ClipNotes.Setup.Pages.ProgressPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <Grid Margin="32,20,32,12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="Установка ClipNotes"
                       FontSize="20" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
            <TextBlock Text="Пожалуйста, подождите..."
                       FontSize="13"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Прогресс -->
        <Border Grid.Row="2"
                Background="{DynamicResource CardBrush}"
                BorderBrush="{DynamicResource CardBorderBrush}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="20,16">
            <StackPanel>
                <TextBlock x:Name="StepText"
                           Text="Подготовка..."
                           FontSize="14" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           Margin="0,0,0,12"/>
                <ProgressBar x:Name="MainProgress"
                             Minimum="0" Maximum="100" Value="0"/>
                <TextBlock x:Name="DetailsText"
                           Margin="0,8,0,0"
                           FontSize="11"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
            </StackPanel>
        </Border>

        <!-- Лог -->
        <Border Grid.Row="4"
                Background="{DynamicResource CardBrush}"
                BorderBrush="{DynamicResource CardBorderBrush}"
                BorderThickness="1"
                CornerRadius="10">
            <ScrollViewer x:Name="LogScroll"
                          VerticalScrollBarVisibility="Auto"
                          Padding="14,10">
                <TextBlock x:Name="LogText"
                           FontSize="11" FontFamily="Consolas"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           TextWrapping="Wrap"/>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
