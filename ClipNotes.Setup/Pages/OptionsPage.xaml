<UserControl x:Class="ClipNotes.Setup.Pages.OptionsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <Grid Margin="32,20,32,12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <StackPanel Grid.Row="0">
            <TextBlock x:Name="PageTitle"
                       FontSize="22" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
            <TextBlock x:Name="PageSubtitle"
                       FontSize="14"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Карточка: путь установки -->
        <Border Grid.Row="2"
                Background="{DynamicResource CardBrush}"
                BorderBrush="{DynamicResource CardBorderBrush}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="16,12">
            <StackPanel>
                <TextBlock x:Name="InstallFolderLabel"
                           FontSize="12" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Margin="0,0,0,8"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="PathBox"
                             Grid.Column="0"
                             TextChanged="PathBox_TextChanged"/>
                    <Button x:Name="BrowseButton"
                            Grid.Column="2"
                            Style="{StaticResource BrowseButtonStyle}"
                            Click="BrowseButton_Click"/>
                </Grid>
                <TextBlock x:Name="SpaceText"
                           Margin="0,8,0,0"
                           FontSize="12"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
            </StackPanel>
        </Border>

        <!-- Карточка: дополнительные параметры -->
        <Border Grid.Row="4"
                Background="{DynamicResource CardBrush}"
                BorderBrush="{DynamicResource CardBorderBrush}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="16,12">
            <StackPanel>
                <TextBlock x:Name="AdditionalLabel"
                           FontSize="12" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Margin="0,0,0,10"/>
                <CheckBox x:Name="DesktopShortcutCheck"
                          IsChecked="True"
                          Checked="DesktopShortcutCheck_Changed"
                          Unchecked="DesktopShortcutCheck_Changed"/>
                <CheckBox x:Name="StartupCheck"
                          Margin="0,10,0,0"
                          Checked="StartupCheck_Changed"
                          Unchecked="StartupCheck_Changed"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
