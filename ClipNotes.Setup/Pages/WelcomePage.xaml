<UserControl x:Class="ClipNotes.Setup.Pages.WelcomePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                    Margin="48,0">
            <!-- Иконка -->
            <Image Source="pack://application:,,,/Resources/ClipNotes1.png"
                   Width="128" Height="128"
                   Stretch="Uniform"
                   RenderOptions.BitmapScalingMode="HighQuality"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,18"/>

            <!-- Название -->
            <TextBlock Text="ClipNotes"
                       FontSize="30" FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       HorizontalAlignment="Center"/>

            <!-- Версия -->
            <TextBlock x:Name="VersionText"
                       FontSize="13"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,4,0,0"/>

            <!-- Разделитель -->
            <Rectangle Height="0.5" Margin="0,22,0,22"
                       Fill="{DynamicResource SeparatorBrush}"/>

            <!-- Описание -->
            <TextBlock x:Name="WelcomeDescText"
                       FontSize="13"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       HorizontalAlignment="Center"
                       TextWrapping="Wrap"
                       TextAlignment="Center"/>

            <TextBlock x:Name="WelcomeHintText"
                       Margin="0,10,0,0"
                       FontSize="12"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       HorizontalAlignment="Center"
                       TextWrapping="Wrap"
                       TextAlignment="Center"/>

            <!-- Выбор языка -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                        Margin="0,18,0,0">
                <TextBlock x:Name="LangLabel"
                           FontSize="12"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>
                <ComboBox x:Name="LangCombo"
                          Width="110"
                          SelectionChanged="LangCombo_SelectionChanged">
                    <ComboBoxItem Content="Русский" Tag="ru"/>
                    <ComboBoxItem Content="English" Tag="en"/>
                </ComboBox>
            </StackPanel>

            <TextBlock Text="by pro4up"
                       FontSize="11"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,16,0,0"
                       Opacity="0.55"/>
        </StackPanel>
    </Grid>
</UserControl>
