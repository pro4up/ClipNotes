<UserControl x:Class="ClipNotes.Setup.Pages.WelcomePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                    Margin="48,0">
            <!-- Иконка -->
            <Image Source="pack://application:,,,/Resources/icon.ico"
                   Width="76" Height="76"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,18"/>

            <!-- Название -->
            <TextBlock Text="ClipNotes"
                       FontSize="30" FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       HorizontalAlignment="Center"/>

            <!-- Версия -->
            <TextBlock x:Name="VersionText"
                       FontSize="13"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,4,0,0"/>

            <!-- Разделитель -->
            <Rectangle Height="0.5" Margin="0,22,0,22"
                       Fill="{DynamicResource SeparatorBrush}"/>

            <!-- Описание -->
            <TextBlock Text="Инструмент для записи таймкодированных заметок"
                       FontSize="13"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       HorizontalAlignment="Center"
                       TextWrapping="Wrap"
                       TextAlignment="Center"/>

            <TextBlock Margin="0,10,0,0"
                       FontSize="12"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       HorizontalAlignment="Center"
                       TextWrapping="Wrap"
                       TextAlignment="Center">
                Мастер установит приложение, инструменты обработки<LineBreak/>
                и модель распознавания речи на ваш компьютер.
            </TextBlock>

            <TextBlock Text="by pro4up"
                       FontSize="11"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,20,0,0"
                       Opacity="0.55"/>
        </StackPanel>
    </Grid>
</UserControl>
