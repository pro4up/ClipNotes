<UserControl x:Class="ClipNotes.Setup.Pages.BackendPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <Grid Margin="32,20,32,12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <StackPanel Grid.Row="0">
            <TextBlock x:Name="PageTitle"
                       FontSize="22" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
            <TextBlock x:Name="PageSubtitle"
                       FontSize="14"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Карточки выбора -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- CPU -->
            <Button x:Name="CpuCard" Grid.Column="0"
                    Style="{StaticResource CardButtonSelectedStyle}"
                    Click="CpuCard_Click"
                    VerticalAlignment="Stretch">
                <StackPanel>
                    <TextBlock Text="CPU"
                               FontSize="18" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Text="OpenBLAS"
                               FontSize="13"
                               Foreground="{DynamicResource AccentBrush}"
                               Margin="0,2,0,12"/>
                    <TextBlock x:Name="CpuDescText"
                               TextWrapping="Wrap" FontSize="13"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <Border Margin="0,14,0,0"
                            Background="#1A8A3A"
                            CornerRadius="6"
                            Padding="8,4">
                        <TextBlock x:Name="CpuRecommendedText"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"/>
                    </Border>
                </StackPanel>
            </Button>

            <!-- CUDA -->
            <Button x:Name="CudaCard" Grid.Column="2"
                    Style="{StaticResource CardButtonStyle}"
                    Click="CudaCard_Click"
                    VerticalAlignment="Stretch">
                <StackPanel>
                    <TextBlock Text="GPU"
                               FontSize="18" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock x:Name="CudaSubtitle"
                               Text="NVIDIA CUDA"
                               FontSize="13"
                               Foreground="{DynamicResource AccentBrush}"
                               Margin="0,2,0,12"/>
                    <TextBlock x:Name="CudaDescText"
                               TextWrapping="Wrap" FontSize="13"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                </StackPanel>
            </Button>
        </Grid>
    </Grid>
</UserControl>
