<Window x:Class="ClipNotes.Setup.Dialogs.UacConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ClipNotes Setup"
        Width="420" Height="210"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="{DynamicResource BgBrush}"
        Icon="pack://application:,,,/Resources/icon.ico">
    <Grid Margin="28,22,28,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Требуются права администратора"
                       FontSize="15" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       Margin="0,0,0,8"/>
            <TextBlock x:Name="MessageText"
                       FontSize="12"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       TextWrapping="Wrap"
                       LineHeight="18"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Отмена"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Margin="0,0,10,0"
                    Click="Cancel_Click"/>
            <Button Content="Продолжить как администратор"
                    Style="{StaticResource AccentButtonStyle}"
                    Click="Confirm_Click"/>
        </StackPanel>
    </Grid>
</Window>
